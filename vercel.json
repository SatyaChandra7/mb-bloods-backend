{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
